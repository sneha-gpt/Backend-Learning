<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen">

  <!-- Navbar -->
  <nav class="bg-blue-600 text-white px-8 py-4 flex justify-between items-center shadow-md">
    <h1 class="text-2xl font-bold">Dashboard</h1>

    <a
      href="/logout"
      class="bg-white text-blue-600 px-4 py-2 rounded-lg hover:bg-gray-100 transition"
    >
      Logout
    </a>
  </nav>

  <!-- Main Content -->
  <div class="max-w-4xl mx-auto mt-10 px-6">

    <div class="bg-white shadow-xl rounded-2xl p-8">

      <h2 class="text-3xl font-bold text-gray-800 mb-4">
        Welcome, <%= user.username %> 👋
      </h2>

      <p class="text-gray-600 mb-6">
        You are successfully logged in using JWT Authentication.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-blue-100 p-5 rounded-xl">
          <h3 class="font-semibold text-lg">Profile</h3>
          <p class="text-sm text-gray-600 mt-2">
            Manage your profile details
          </p>
        </div>

        <div class="bg-green-100 p-5 rounded-xl">
          <h3 class="font-semibold text-lg">Security</h3>
          <p class="text-sm text-gray-600 mt-2">
            Update password & settings
          </p>
        </div>

        <div class="bg-purple-100 p-5 rounded-xl">
          <h3 class="font-semibold text-lg">Activity</h3>
          <p class="text-sm text-gray-600 mt-2">
            View account activity
          </p>
        </div>

      </div>

    </div>

  </div>

</body>
</html>